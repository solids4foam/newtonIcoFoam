FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     newtonIcoFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         50;

deltaT          0.025;

writeControl    timeStep;

writeInterval   4;

purgeWrite      200;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep no;

maxCo 10;

functions
{
   forces
   {
       type                forces;
       libs                ( "libforces.so" );
       writeControl        timeStep;
       writeInterval       1;
       patches             (cylinderWall);
       "pName|p"           p;
       "UName|U"           U;
       "rhoName|rho"       rhoInf;
       log                 false;
       rhoInf              1;
       CofR                (0.5 0.1 0);
   }
}

