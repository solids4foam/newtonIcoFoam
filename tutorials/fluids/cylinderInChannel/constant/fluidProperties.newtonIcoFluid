FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fluidProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

fluidModel newtonIcoFluid;

newtonIcoFluidCoeffs
{
    // Scaling of pressure equation relative to the momentum
    pressureScaleFactor 1.0;

    stabilisation
    {
        momentum
        {
            type        diffStencilLaplacian;
            scaleFactor 0.0;
        }

        pressure
        {
            type        RhieChow;
            scaleFactor 1.0;
        }
    }
}

