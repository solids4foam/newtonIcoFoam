NEWTONICOFLUID_ROOT := ../..

sinclude $(NEWTONICOFLUID_ROOT)/etc/wmake-options
sinclude $(NEWTONICOFLUID_ROOT)/../etc/wmake-options

ifneq (,$(findstring -DFOAMEXTEND, $(VERSION_SPECIFIC_INC)))
    VERSION_SPECIFIC_LIBS = \
        -lincompressibleTransportModels -lincompressibleTurbulenceModel \
        -lincompressibleRASModels -lincompressibleLESModels -llduSolvers \
        -lfiniteArea -loversetMesh -loversetDynamicFvMesh

else ifneq (,$(findstring -DOPENFOAM_ORG, $(VERSION_SPECIFIC_INC)))
    VERSION_SPECIFIC_LIBS = \
        -lmomentumTransportModels -lincompressibleMomentumTransportModels \
        -lmeshTools -lfvMotionSolvers
else
    VERSION_SPECIFIC_LIBS = \
        -lturbulenceModels -lincompressibleTurbulenceModels \
        -lfvMotionSolvers -lfvOptions -lsampling \
        -lincompressibleTransportModels -lfiniteArea
endif

ifdef PETSC_DIR
    ifneq (,$(findstring -DFOAMEXTEND, $(VERSION_SPECIFIC_INC)))
        include $(RULES)/mplib$(WM_MPLIB)
    else ifneq (,$(findstring -DOPENFOAM_ORG, $(VERSION_SPECIFIC_INC)))
        include $(GENERAL_RULES)/mplibType
    else
        include $(GENERAL_RULES)/mpi-rules
    endif
    VERSION_SPECIFIC_INC += \
        $(PINC) -I$(PETSC_DIR)/include -I$(PETSC_DIR)/$(PETSC_ARCH)/include \
        -DUSE_PETSC
    VERSION_SPECIFIC_LIBS += -L$(PETSC_DIR)/$(PETSC_ARCH)/lib -lpetsc
endif

EXE_INC = \
    -Wno-old-style-cast -Wno-deprecated-declarations \
    $(VERSION_SPECIFIC_INC) \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/finiteArea/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/fvMotionSolver/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/turbulenceModels \
    -I$(LIB_SRC)/turbulenceModels/incompressible/RAS/RASModel \
    -I$(LIB_SRC)/turbulenceModels/incompressible/turbulenceModel \
    -I$(LIB_SRC)/TurbulenceModels/turbulenceModels/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/incompressible/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/momentumTransportModels/lnInclude \
    -I$(LIB_SRC)/MomentumTransportModels/incompressible/lnInclude \
    -I$(LIB_SRC)/transportModels \
    -I$(LIB_SRC)/transportModels/lnInclude \
    -I$(LIB_SRC)/transportModels/incompressible/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/meshMotion/fvMotionSolver/lnInclude

LIB_LIBS = \
    $(VERSION_SPECIFIC_LIBS) \
    -lfiniteVolume \
    -ldynamicFvMesh \
    -ldynamicMesh \
    -lmeshTools \
    -ltopoChangerFvMesh
