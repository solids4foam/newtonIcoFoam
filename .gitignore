# git-ls-files --others --exclude-from=.git/info/exclude
# Lines that start with '#' are comments.

# PETSc state file
.petsc_state

notes.txt
todo*
tutorialsTest*
regressionTests*
codex*.md

# Build log files
log.Allwmake
log.Allcheck

# Library files which are replaced by links
src/solids4FoamModels/Make/files

# withDefaultValues dictionaries files generated by the tutorial scripts
*.withDefaultValues

# editor and misc backup files - anywhere
*~
.*~
*.bak
*.bak[0-9][0-9]
\#*\#

# file-browser settings - anywhere
.directory

# CVS recovered versions - anywhere
.#*

# objects and archives - anywhere
*.[oa]
*.la
*.so
*.jar
*.dylib

# derived files
lex.yy.c

# Corefiles
core

# dependency files - anywhere
*.dep

# lnInclude (symlink) folders - anywhere
lnInclude

# A hidden file created by the Mac OS X Finder.
.DS_Store

# build folders - anywhere
/platforms/
linux*Gcc*/
linux*Icc*/
darwin*Gcc*/
darwin*Intel*/
darwin*Arm*/
darwin*Clang*/
linuxming*/
SiCortex*Gcc*/
solaris*Gcc*/
SunOS*Gcc*/

# generated files in the main directory (e.g. ReleaseNotes-?.?.html)
/*.html

# patch residue
*.rej

# python-compile
*.pyc

# other stuff
.build
.hgignore
.timeStamp

# source packages - anywhere
*.tar.bz2
*.tar.gz
*.tar
*.tgz
*.gtgz

# Compilation database for clangd
compile_commands.json
.compile_commands.json

# Hand-authored list of global compiler flags
compile_flags.txt
.compile_flags.txt

# Temporary indexing cache generated by clangd for faster code navigation
.cache/

# end-of-file
